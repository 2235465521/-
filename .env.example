# ---------- 数据库配置 (MySQL) ----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mydate

# ---------- 服务运行配置 ----------
HOST=0.0.0.0
PORT=5000
OPEN_BROWSER=true

# ---------- 磁盘文件目录配置 (Windows 可省略以自动检测，Linux 部署时必须修改配置) ----------
# 标准 PDF 根目录 (Linux 示例: /mnt/array/标准文件下载)
PDF_ROOT=
# 标准扫描根目录 (Linux 示例: /mnt/array)
PDF_SEARCH_ROOT=
# 团标征求意见稿目录 (Linux 示例: /mnt/array/标准文件下载/团体标准/团标征求意见稿下载)
TUANGBIAO_DIR=
# 制度文件目录 (Linux 示例: /mnt/array/制度文件)
ZHIDU_DIR=
# SQL 导入目录（构建索引时使用，Linux 示例: /opt/mydate）
SQL_DUMP_DIR=
